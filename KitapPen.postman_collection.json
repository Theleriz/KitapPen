            "url": { "raw": "{{baseUrl}}/api/reading/stats/", "host": ["{{baseUrl}}"], "path": ["api", "reading", "stats", ""] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"total_seconds\": 7200,\n  \"streak_days\": 3,\n  \"avg_per_day\": 2400.0,\n  \"sessions_count\": 9\n}"
