          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"email_notifications_enabled\": true,\n  \"reminder_hour\": 20,\n  \"last_sent_at\": null\n}"
            }
          ]
        },
        {
          "name": "Send Notification (Admin only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/notifications/send/", "host": ["{{baseUrl}}"], "path": ["api", "notifications", "send", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Reading reminder\",\n  \"message\": \"Don't forget to read today!\",\n  \"user_ids\": [1, 2]\n}"
            }
