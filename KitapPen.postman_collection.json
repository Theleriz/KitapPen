            "url": { "raw": "{{baseUrl}}/api/notes/1/", "host": ["{{baseUrl}}"], "path": ["api", "notes", "1", ""] }
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "body": ""
            }
          ]
        }
      ]
    },
    {
      "name": "Reading",
      "item": [
        {
          "name": "Reading Ping",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/reading/ping/", "host": ["{{baseUrl}}"], "path": ["api", "reading", "ping", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"frame\": \"<base64-encoded-image-data>\",\n  \"session_id\": null\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"ok\": true,\n  \"reading\": true,\n  \"confidence\": 0.87,\n  \"session_id\": 5,\n  \"total_seconds\": 15\n}"
            }
