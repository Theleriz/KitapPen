              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/notes/1/", "host": ["{{baseUrl}}"], "path": ["api", "notes", "1", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"book\": 1,\n  \"content\": \"Updated note content\",\n  \"page_number\": 45\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"book\": 1,\n  \"book_title\": \"Clean Code\",\n  \"content\": \"Updated note content\",\n  \"page_number\": 45,\n  \"created_at\": \"2026-04-20T12:00:00Z\",\n  \"updated_at\": \"2026-04-21T09:00:00Z\"\n}"
            }
          ]
