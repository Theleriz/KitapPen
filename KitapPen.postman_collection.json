              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/reading/stop/", "host": ["{{baseUrl}}"], "path": ["api", "reading", "stop", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": 5\n}"
            }
