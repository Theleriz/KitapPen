            ],
            "url": { "raw": "{{baseUrl}}/api/notes/", "host": ["{{baseUrl}}"], "path": ["api", "notes", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"book\": 1,\n  \"content\": \"Great chapter on functions\",\n  \"page_number\": 42\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 1,\n  \"book\": 1,\n  \"book_title\": \"Clean Code\",\n  \"content\": \"Great chapter on functions\",\n  \"page_number\": 42,\n  \"created_at\": \"2026-04-20T12:00:00Z\",\n  \"updated_at\": \"2026-04-20T12:00:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Get Note Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/notes/1/", "host": ["{{baseUrl}}"], "path": ["api", "notes", "1", ""] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"book\": 1,\n  \"book_title\": \"Clean Code\",\n  \"content\": \"Great chapter on functions\",\n  \"page_number\": 42,\n  \"created_at\": \"2026-04-20T12:00:00Z\",\n  \"updated_at\": \"2026-04-20T12:00:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Update Note",
